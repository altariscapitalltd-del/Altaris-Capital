# ─────────────────────────────────────────────────────────────
# Copy to .env.local for local dev.
# For Vercel deployment, set these in Project Settings →
# Environment Variables (never commit real secrets to Git).
# ─────────────────────────────────────────────────────────────

# ── Database (Neon / PlanetScale / Supabase) ─────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Authentication ────────────────────────────────────────────
JWT_SECRET="change-me-min-32-chars-random-string"
ADMIN_JWT_SECRET="change-me-admin-min-32-chars-random"

# ── Pusher Channels (real-time) ───────────────────────────────
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="eu"

# ── Email (Gmail App Password) ────────────────────────────────
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ── Vercel Blob (KYC document storage) ───────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Telegram KYC alerts (optional) ───────────────────────────
# Create a bot with @BotFather, message the bot once, then set your chat ID.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_KYC_CHAT_ID=""

# ── Telegram admin notifications ─────────────────────────────
ADMIN_TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""

# ── App public URL (used in emails and referral links) ────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Firebase (push notifications — optional) ─────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""
FIREBASE_SERVICE_ACCOUNT_JSON=""

# ── Fiat on-ramp providers (optional deep-link URLs) ─────────
# NEXT_PUBLIC_MOONPAY_WIDGET_URL="https://buy.moonpay.com?apiKey=pk_live_XXX"
# NEXT_PUBLIC_RAMP_WIDGET_URL="https://ramp.network/buy/?hostApiKey=XXX"
# NEXT_PUBLIC_TRANSAK_WIDGET_URL="https://global.transak.com?apiKey=XXX"

# ── Per-user USDC deposit addresses + on-chain watcher ───────
# When DEPOSIT_WALLET_XPUB is set, each user gets a unique deposit address
# derived from this account-level xpub (path m/44'/60'/0'/0). The SAME 0x
# address receives USDC on every EVM chain. Until it's set, the app falls back
# to the shared admin USDC address. This is the extended PUBLIC key only — it
# generates addresses but CANNOT spend. Keep the seed phrase OFFLINE, never here.
DEPOSIT_WALLET_XPUB=""
# Alchemy Address Activity webhook signing keys (one per chain webhook),
# comma-separated — used to verify incoming webhook calls.
ALCHEMY_SIGNING_KEYS=""
# Alchemy Notify auth token + webhook ids (comma-separated) so newly assigned
# addresses are auto-registered with the watcher.
ALCHEMY_AUTH_TOKEN=""
ALCHEMY_WEBHOOK_IDS=""

# ── Market data ───────────────────────────────────────────────
FINNHUB_API_KEY=""          # https://finnhub.io — free tier, used for live stock quotes
# FRED_API_KEY=""           # https://fred.stlouisfed.org/docs/api/api_key.html — bond yield data
