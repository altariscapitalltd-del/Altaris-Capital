# Copy to .env.local and fill in. For production (Vercel), set these in Project Settings → Environment Variables.

# Database
DATABASE_URL="postgresql://..."

# Auth
JWT_SECRET="..."
ADMIN_JWT_SECRET="..."

# Profile avatars (required for production — Vercel Blob)
# Create a Blob store in Vercel dashboard, then paste the token here.
BLOB_READ_WRITE_TOKEN=""

# Fiat deposit (optional — Moonpay opens in-app by default)
# Default: https://buy.moonpay.com. Add your API key for full widget: https://buy.moonpay.com?apiKey=pk_live_XXX
# NEXT_PUBLIC_MOONPAY_WIDGET_URL="https://buy.moonpay.com"

# Firebase (push notifications)
# Public web config (from Firebase console → Project settings → General)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Web push VAPID key (Firebase console → Project settings → Cloud Messaging → Web configuration)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Server key for sending notifications from backend (NEVER expose this on the client)
FIREBASE_SERVER_KEY=""

# Optional: base URL for push deep links (e.g. https://yourapp.com)
# NEXT_PUBLIC_APP_URL="https://yourapp.com"

# Email, Pusher Channels, etc. — add as needed from your .env
