generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  phone                String?
  passwordHash         String
  role                 Role      @default(USER)
  kycStatus            KycStatus @default(NOT_SUBMITTED)
  isActive             Boolean   @default(true)
  withdrawEnabled      Boolean   @default(true)
  bonusClaimed         Boolean   @default(false)
  profilePicture       String?
  pushSubscription     Json?
  lastKnownLat         Float?
  lastKnownLng         Float?
  lastKnownCity        String?
  lastKnownCountry     String?
  locationUpdatedAt    DateTime?
  emailVerifiedAt      DateTime?
  rewardBalance        Float     @default(0)
  referralCode         String    @unique
  referredById         String?
  vipInvestor          Boolean   @default(false)
  createdAt            DateTime  @default(now())
  lastLoginAt          DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?

  referredBy        User?                   @relation("UserReferrals", fields: [referredById], references: [id])
  referredUsers     User[]                  @relation("UserReferrals")
  balances          Balance[]
  transactions      Transaction[]
  investments       Investment[]
  otps              OTP[]
  kyc               KycSubmission?
  notifications     Notification[]
  conversation      Conversation?
  auditTargets      AdminAuditLog[]         @relation("TargetUser")
  referralsSent     Referral[]              @relation("Referrer")
  referralsReceived Referral[]              @relation("Referee")
  referralRewards   ReferralReward[]
  campaignBonuses   ReferralCampaignBonus[]

  @@map("users")
}

model Balance {
  id        String            @id @default(cuid())
  userId    String
  currency  String
  amount    Float             @default(0)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots BalanceSnapshot[]

  @@unique([userId, currency])
  @@map("balances")
}

model BalanceSnapshot {
  id        String   @id @default(cuid())
  balanceId String
  amount    Float
  createdAt DateTime @default(now())
  balance   Balance  @relation(fields: [balanceId], references: [id], onDelete: Cascade)

  @@map("balance_snapshots")
}

model Transaction {
  id        String            @id @default(cuid())
  userId    String
  type      TransactionType
  amount    Float
  currency  String
  status    TransactionStatus @default(PENDING)
  txHash    String?
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Investment {
  id          String           @id @default(cuid())
  userId      String
  planId      String
  planName    String
  amount      Float
  dailyRoi    Float
  startDate   DateTime         @default(now())
  endDate     DateTime
  status      InvestmentStatus @default(ACTIVE)
  totalEarned Float            @default(0)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investments")
}

model OTP {
  id        String     @id @default(cuid())
  userId    String
  code      String
  purpose   OTPPurpose
  expiresAt DateTime
  used      Boolean    @default(false)
  attempts  Int        @default(0)
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

model KycSubmission {
  id              String    @id @default(cuid())
  userId          String    @unique
  fullName        String
  dateOfBirth     String
  address         String
  country         String?
  documentType    String?
  documentNumber  String?
  documentPath    String
  selfiePath      String?
  status          KycStatus @default(PENDING_REVIEW)
  rejectionReason String?
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_submissions")
}

model Referral {
  id                 String           @id @default(cuid())
  referrerId         String
  refereeId          String           @unique
  codeUsed           String
  status             ReferralStatus   @default(PENDING)
  signedUpAt         DateTime         @default(now())
  emailVerifiedAt    DateTime?
  identityVerifiedAt DateTime?
  minimumDepositAt   DateTime?
  qualifiedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  referrer           User             @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee            User             @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)
  ReferralReward     ReferralReward[]

  @@index([referrerId, status])
  @@map("referrals")
}

model ReferralReward {
  id          String             @id @default(cuid())
  userId      String
  referralId  String?
  kind        ReferralRewardKind
  amount      Float
  status      RewardStatus       @default(CREDITED)
  tierTarget  Int?
  campaignId  String?
  level       Int?
  sourceTxId  String?
  description String
  createdAt   DateTime           @default(now())
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referral    Referral?          @relation(fields: [referralId], references: [id], onDelete: SetNull)
  campaign    ReferralCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, kind])
  @@map("referral_rewards")
}

model ReferralCampaign {
  id                         String                  @id @default(cuid())
  title                      String
  description                String
  startAt                    DateTime
  endAt                      DateTime
  requiredQualifiedReferrals Int
  bonusAmount                Float
  isActive                   Boolean                 @default(true)
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  rewards                    ReferralReward[]
  bonuses                    ReferralCampaignBonus[]

  @@map("referral_campaigns")
}

model ReferralCampaignBonus {
  id         String           @id @default(cuid())
  campaignId String
  userId     String
  createdAt  DateTime         @default(now())
  campaign   ReferralCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("referral_campaign_bonuses")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info")
  read      Boolean  @default(false)
  url       String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String    @unique
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  sender         String
  content        String
  attachmentPath String?
  readStatus     String       @default("sent")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model WalletAddress {
  id        String   @id @default(cuid())
  currency  String   @unique
  address   String
  updatedAt DateTime @updatedAt
  updatedBy String   @default("system")

  @@map("wallet_addresses")
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String
  targetUserId String?
  details      Json?
  createdAt    DateTime @default(now())
  targetUser   User?    @relation("TargetUser", fields: [targetUserId], references: [id])

  @@map("admin_audit_logs")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  INVESTMENT
  PROFIT
  BONUS
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  REJECTED
  CANCELLED
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OTPPurpose {
  SIGNUP
  LOGIN
  WITHDRAWAL
  KYC
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REJECTED
}

enum ReferralRewardKind {
  REFERRER_BONUS
  REFEREE_BONUS
  TIER_BONUS
  CAMPAIGN_BONUS
  NETWORK_COMMISSION
  LEADERBOARD_BONUS
}

enum RewardStatus {
  PENDING
  CREDITED
  REVOKED
}
